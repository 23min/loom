{
  "name": "loom Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "mounts": [
    "source=/tmp/.loom-claude-mount,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=/tmp/.loom-claude-plugins-mount,target=/home/vscode/.claude/plugins,type=bind,consistency=cached",
    "source=/tmp/.loom-gh-mount,target=/home/vscode/.config/gh,type=bind,consistency=cached"
  ],
  "updateContentCommand": "bash .devcontainer/init.sh",
  "postCreateCommand": "bash .devcontainer/init.sh",
  "remoteUser": "vscode",
  "containerEnv": {
    "LOOM_DEVCONTAINER": "1"
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "yaml.validate": true,
        "yaml.format.enable": true
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "dafny-lang.ide-vscode",
        "redhat.vscode-yaml",
        "anthropic.claude-code",
        "mhutchie.git-graph",
        "editorconfig.editorconfig",
        "github.vscode-github-actions",
        "shd101wyy.markdown-preview-enhanced"
      ]
    }
  }
}
